# Database Configuration
# PostgreSQL with PGVector extension
DATABASE_URL=postgresql://raguser:ragpass@localhost:5432/postgres

# =============================================
# Model Provider Configuration
# =============================================

# Option 1: OpenAI (Cloud)
# Get from https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_BASE_URL=
# LLM_CHOICE=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# Option 2: Ollama (Local)
# Changed 'localhost' to 'host.docker.internal' to reach Ollama on your Mac
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=ollama
LLM_CHOICE=qwen2.5-coder
EMBEDDING_MODEL=nomic-embed-text

# Available Ollama models (examples):
# LLM: llama3.2:3b, qwen2.5:7b, mistral:7b
# Embedding: qwen3-embedding, nomic-embed-text, mxbai-embed-large

# Development Settings
LOG_LEVEL=INFO
DEBUG_MODE=false
